{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "**.csproj"
          ],
          "exclude": [
            "**/bin/**",
            "**/obj/**"
          ],
          "src": "../src/Hiero"
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "filter": "./filter.yml"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.yml"
        ],
        "src": "api",
        "dest": "api"
      },
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "bin/**",
          "obj/**",
          "filter.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "styles/**",
          "llms.txt",
          "llms-full.txt"
        ]
      }
    ],
    "overwrite": "apispec/*.md",
    "xrefService": [
      "https://xref.docs.microsoft.com/query?uid={uid}"
    ],
    "postProcessors": [],
    "globalMetadata": {
      "_appTitle": "Hiero",
      "_appFooter": "<span>.NET Client Library for Hiero Network and Hedera Hashgraph</span>",
      "_appLogoPath": "images/logo.svg",
      "_appFaviconPath": "images/favicon.ico"
    },
    "dest": "bin/site",
    "markdownEngineName": "markdig",
    "template": [
      "default",
      "templates"
    ],
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}
